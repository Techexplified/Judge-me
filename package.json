{
  "name": "judgeme",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "postinstall": "prisma generate",
    "setup": "dotenv -e .env.judgeme -- prisma generate && dotenv -e .env.judgeme -- prisma db push",
    "db:push": "dotenv -e .env.judgeme -- prisma db push",
    "dev": "dotenv -e .env.judgeme -- shopify app dev --theme-app-extension-port 9494",
    "dev:verbose": "dotenv -e .env.judgeme -- shopify app dev --verbose --theme-app-extension-port 9494",
    "dev:clean": "dotenv -e .env.judgeme -- shopify app dev clean",
    "dev:tunnel": "dotenv -e .env.judgeme -- shopify app dev --theme-app-extension-port 9494",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run start",
    "lint": "eslint --ignore-path .eslintignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "dev:localhost": "dotenv -e .env.judgeme -- shopify app dev --use-localhost --theme-app-extension-port 9494",
    "db:init": "dotenv -e .env.judgeme -- node scripts/init-db.mjs",
    "dev:kill": "powershell -NoProfile -Command \"Get-CimInstance Win32_Process -Filter 'name=\\\"node.exe\\\"' | Where-Object { ($_.CommandLine -match '@shopify\\\\cli\\\\bin\\\\run.js') -or ($_.CommandLine -match 'shopify app dev') -or ($_.CommandLine -match '@react-router\\\\dev\\\\bin.js') } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }\""
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "@react-router/fs-routes": "^7.1.5",
    "@react-router/node": "^7.1.5",
    "@react-router/serve": "^7.1.5",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/shopify-app-react-router": "^1.0.4",
    "@shopify/shopify-app-session-storage-prisma": "^6.0.2",
    "isbot": "^5.1.1",
    "prisma": "^6.3.0",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.1.5",
    "react-router-dom": "^7.11.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@react-router/dev": "^7.1.5",
    "@shopify/api-codegen-preset": "^1.1.1",
    "@shopify/app-bridge-types": "^0.0.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.2.2",
    "vite": "^5.4.11"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "karan"
}
