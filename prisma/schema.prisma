generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Review {
  id           String   @id @default(uuid())
  shop         String
  productId    String
  productName  String?
  productImage String?
  rating       Int
  title        String?
  comment      String
  author       String
  email        String?
  status       String   @default("PENDING")
  reply            String?
  replyDate        DateTime?
  originalComment  String?
  originalTitle    String?
  translatedLang   String?
  createdAt        DateTime @default(now())
  media            ReviewMedia[]

  @@index([shop])
  @@index([shop, createdAt])
  @@index([shop, status, createdAt])
  @@index([shop, productId, status, createdAt])
  @@index([shop, status, rating])
}

model ReviewMedia {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  /// "image" | "video"
  type      String
  mimeType  String
  filename  String?
  data      Bytes
  createdAt DateTime @default(now())

  @@index([reviewId])
  @@index([reviewId, type])
}

model Settings {
  id        String   @id @default(uuid())
  shop      String   @unique
  config    String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Binary shop assets (brand logos, etc.) — kept out of Settings JSON so Neon
/// data-transfer is not multiplied on every settings read/write.
model ShopAsset {
  id        String   @id @default(uuid())
  shop      String
  /// e.g. "brandLogo"
  key       String
  mimeType  String
  filename  String?
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
  @@index([shop])
}

model QuestionAndAnswer {
  id            String    @id @default(uuid())
  shop          String
  productId     String
  productName   String?
  question      String
  author        String
  email         String?
  status        String    @default("UNANSWERED")
  reply         String?
  replyDate     DateTime?
  replyPublished Boolean  @default(false)
  createdAt     DateTime  @default(now())
  @@index([shop])
  @@index([shop, createdAt])
  @@index([shop, status, createdAt])
  @@index([shop, productId, status, createdAt])
}

/// Tracks per-shop install, billing plan, and review limits.
model Shop {
  id                 String    @id @default(uuid())
  shop               String    @unique
  installedAt        DateTime  @default(now())
  /// Legacy field — kept for migration compatibility
  trialEndsAt        DateTime?
  /// Legacy field — superseded by plan + subscriptionStatus
  planStatus         String    @default("free")
  /// "free" | "pro"
  plan               String    @default("free")
  subscriptionId     String?
  /// ACTIVE | PENDING | CANCELLED | FROZEN | EXPIRED | DECLINED
  subscriptionStatus String?
  billingTrialEndsAt DateTime?
  /// App-managed complimentary Pro for pre-billing merchants (one-time)
  graceTrialEndsAt   DateTime?
  graceTrialGrantedAt DateTime?
  reviewsThisMonth   Int       @default(0)
  /// Calendar month key e.g. "2026-06"
  reviewsMonthKey    String?
  uninstalledAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

/// Per-shop monthly usage counters for Pro metered features.
model FeatureUsage {
  id         String @id @default(uuid())
  shop       String
  featureKey String
  /// Calendar month key e.g. "2026-06" (UTC)
  monthKey   String
  count      Int    @default(0)

  @@unique([shop, featureKey, monthKey])
  @@index([shop, monthKey])
}

// Represents a cluster of stores owned by the same merchant
model StoreGroup {
  id          String           @id @default(uuid())
  name        String           // E.g., "TechExplified Global Group"
  ownerEmail  String           // Merchant's main administrative email
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  // Relations
  members     GroupStoreLink[]
}

// Junction table linking Shopify shops to a StoreGroup
model GroupStoreLink {
  id           String     @id @default(uuid())
  groupId      String
  shop         String     @unique // Shopify domain (e.g., "store-us.myshopify.com")
  role         String     @default("MEMBER") // "PRIMARY" or "MEMBER"
  createdAt    DateTime   @default(now())

  // Relations
  group        StoreGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

// Cached product details to facilitate efficient SKU/Handle matching without making live Shopify API calls
model ProductIndex {
  id          String   @id @default(uuid())
  shop        String   // Shopify domain
  productId   String   // Shopify Product ID
  handle      String   // Shopify Product Handle (URL)
  sku         String?  // Primary SKU (or consolidated list of variant SKUs)
  title       String
  updatedAt   DateTime @updatedAt

  @@unique([shop, productId])
  @@index([sku])
  @@index([handle])
  @@index([shop, sku])
  @@index([shop, handle])
}
