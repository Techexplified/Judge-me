generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Review {
  id           String   @id @default(uuid())
  shop         String
  productId    String
  productName  String?
  productImage String?
  rating       Int
  title        String?
  comment      String
  author       String
  email        String?
  status       String   @default("PENDING")
  reply        String?
  replyDate    DateTime?
  createdAt    DateTime @default(now())
}

model Settings {
  id        String   @id @default(uuid())
  shop      String   @unique
  config    String   @db.Text
  updatedAt DateTime @updatedAt
}

/// Tracks per-shop install timestamp and trial window.
model Shop {
  id           String   @id @default(uuid())
  shop         String   @unique
  installedAt  DateTime @default(now())
  trialEndsAt  DateTime
  /// "trial" | "active" | "expired"
  planStatus   String   @default("trial")
  uninstalledAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Represents a cluster of stores owned by the same merchant
model StoreGroup {
  id          String           @id @default(uuid())
  name        String           // E.g., "TechExplified Global Group"
  ownerEmail  String           // Merchant's main administrative email
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  // Relations
  members     GroupStoreLink[]
}

// Junction table linking Shopify shops to a StoreGroup
model GroupStoreLink {
  id           String     @id @default(uuid())
  groupId      String
  shop         String     @unique // Shopify domain (e.g., "store-us.myshopify.com")
  role         String     @default("MEMBER") // "PRIMARY" or "MEMBER"
  createdAt    DateTime   @default(now())

  // Relations
  group        StoreGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// Cached product details to facilitate efficient SKU/Handle matching without making live Shopify API calls
model ProductIndex {
  id          String   @id @default(uuid())
  shop        String   // Shopify domain
  productId   String   // Shopify Product ID
  handle      String   // Shopify Product Handle (URL)
  sku         String?  // Primary SKU (or consolidated list of variant SKUs)
  title       String
  updatedAt   DateTime @updatedAt

  @@unique([shop, productId])
  @@index([sku])
  @@index([handle])
}
