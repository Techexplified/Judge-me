{% comment %}
  JudgeMe Core — global app embed (Loox Core Script equivalent).
  Loads shared storefront bootstrap on all pages when enabled in Theme Settings → App embeds.
{% endcomment %}
<script>
  window.__JUDGEME__ = window.__JUDGEME__ || {};
  window.__JUDGEME__.shop = {{ shop.permanent_domain | json }};
  window.__JUDGEME__.apiBase = "/apps/judgeme-reviews";
</script>
<script src="{{ 'judgeme-core.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "JudgeMe Core",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Required for review widgets, translation, and analytics on your storefront. Enable this once, then add individual widgets from the JudgeMe app."
    }
  ]
}
{% endschema %}
