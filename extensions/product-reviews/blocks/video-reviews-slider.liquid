{% if block.settings.enable %}
<div
  id="jd-video-slider-root"
  class="jd-video-slider-root"
  data-widget="video-reviews-slider"
  data-shop="{{ shop.permanent_domain }}"
  data-api-base="/apps/judgeme-reviews"
  data-heading="{{ block.settings.heading | escape }}"
  data-limit="{{ block.settings.limit }}"
></div>
<script src="{{ 'video-slider.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Video Reviews Slider",
  "target": "section",
  "enabled_on": {
    "templates": ["index", "product", "page", "collection"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable video reviews slider",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Video Reviews"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Maximum videos",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8
    }
  ]
}
{% endschema %}
