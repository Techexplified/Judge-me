{% if block.settings.enable %}
<div
  id="jd-customer-love-root"
  class="jd-customer-love-root"
  data-widget="customer-love-page"
  data-shop="{{ shop.permanent_domain }}"
  data-api-base="/apps/verdict-product-reviews"
  data-heading="{{ block.settings.heading | escape }}"
  data-limit="{{ block.settings.limit }}"
></div>
<script src="{{ 'media-lightbox.js' | asset_url }}" defer></script>
<script src="{{ 'customer-love.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Customer Love Page",
  "target": "section",
  "enabled_on": {
    "templates": ["page", "index"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable customer love page",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Customer Love"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Reviews per page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
