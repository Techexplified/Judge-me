{% if block.settings.enable %}
<div id="testimonials-widget-root"
     data-shop="{{ shop.permanent_domain }}"
     data-api-base="/apps/judgeme-reviews"
     data-heading="{{ block.settings.heading | escape }}">
</div>
<script src="{{ 'testimonials-widget.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Testimonials",
  "target": "section",
  "settings": [
    { "type": "checkbox", "id": "enable", "label": "Enable testimonials", "default": true }
  ]
}
{% endschema %}