{% if block.settings.enable %}
<div
  id="testimonials-widget-root"
  class="jd-testimonials-root"
  data-widget="testimonials"
  data-shop="{{ shop.permanent_domain }}"
  data-api-base="/apps/judgeme-reviews"
  data-heading="{{ block.settings.heading | escape }}"
  data-limit="{{ block.settings.limit }}"
></div>
<script src="{{ 'testimonials-widget.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Testimonials",
  "target": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable testimonials",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Testimonials"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Maximum reviews",
      "min": 3,
      "max": 15,
      "step": 1,
      "default": 5
    }
  ]
}
{% endschema %}