{% comment %}
  Verdict Core — global app embed (Loox Core Script equivalent).
  Loads shared storefront bootstrap on all pages when enabled in Theme Settings → App embeds.
{% endcomment %}
<script>
  window.__VERDICT__ = window.__VERDICT__ || {};
  window.__VERDICT__.shop = {{ shop.permanent_domain | json }};
  window.__VERDICT__.apiBase = "/apps/judgeme-reviews";
</script>
<script src="{{ 'verdict-core.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Verdict Core",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Required for review widgets, translation, and analytics on your storefront. Enable this once, then add individual widgets from the Verdict Product Reviews app."
    }
  ]
}
{% endschema %}
